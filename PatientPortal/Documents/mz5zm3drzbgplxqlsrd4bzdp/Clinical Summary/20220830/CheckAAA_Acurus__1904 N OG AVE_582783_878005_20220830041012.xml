          <entry typeCode="DRIV" xmlns="urn:hl7-org:v3">
            <act classCode="ACT" moodCode="EVN">
              <!-- ** Allergy Concern Act (V3) ** -->
              <templateId root="2.16.840.1.113883.10.20.22.4.30" extension="2015-08-01" />
